# WitBlox AI — local laptop test config
# Copy to: main/xiaozhi-server/data/.config.yaml
# Gemini key: https://aistudio.google.com/apikey
# If your PC IP changes, update the URLs below and rebuild ESP32 firmware OTA URL

server:
  websocket: ws://192.168.0.103:8000/xiaozhi/v1/
  vision_explain: http://192.168.0.103:8003/mcp/vision/explain

prompt: |
  I am WitBlox AI, a friendly voice assistant for learning and DIY projects.
  I speak clearly, keep answers short, and help users in simple English or Hindi when asked.

selected_module:
  LLM: GeminiLLM
  TTS: EdgeTTS
  ASR: FunASR
  Intent: function_call

LLM:
  GeminiLLM:
    api_key: YOUR_GEMINI_API_KEY
    model_name: gemini-2.5-flash
    http_proxy: ""
    https_proxy: ""
