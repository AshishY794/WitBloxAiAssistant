# WitBlox AI — dashboard mode example
# Copy to: main/xiaozhi-server/data/.config.yaml
# Configure LLM keys and persona in the web dashboard (http://127.0.0.1:8001)

server:
  ip: 0.0.0.0
  port: 8000
  http_port: 8003
  # India Standard Time (UTC+05:30) — hours; OTA multiplies by 60 → minutes
  timezone_offset: +5.5
  vision_explain: http://192.168.0.103:8003/mcp/vision/explain

manager-api:
  url: http://127.0.0.1:8002/xiaozhi
  secret: YOUR_SERVER_SECRET_FROM_DASHBOARD

prompt_template: agent-base-prompt.txt
